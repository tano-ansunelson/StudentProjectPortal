@using StudentProjectPortal.ViewModels;
@model ChangePasswordViewModel
@{
    ViewBag.Title = "Change Password";
}

<div class="container-fluid min-vh-100 d-flex p-0">
    <div class="row flex-fill g-0">

        <!-- LEFT: Change Password Form -->
        <div class="col-12 col-md-6 d-flex align-items-center justify-content-center bg-dark p-4">
            <div class="card shadow-lg rounded-4 p-4 w-100" style="max-width: 420px; background: #1e1f24; border: none;">

                <!-- Header -->
                <div class="text-center mb-4 text-white">
                    <h1 class="h3 fw-bold">Change Password</h1>
                    <p class="text-secondary mb-1">Set a new password for your account</p>
                </div>

                <!-- FORM -->
                <form method="post" asp-action="ChangePassword" asp-controller="Account">

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="form-label text-white-50">Email</label>
                        <input asp-for="Email" class="form-control bg-dark text-white border-secondary"
                               placeholder="me@example.com" required  readonly/>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- New Password -->
                    <div class="mb-3">
                        <label class="form-label text-white-50">New Password</label>
                        <input asp-for="NewPassword" type="password"
                               class="form-control bg-dark text-white border-secondary"
                               placeholder="Enter new password" required />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-3">
                        <label class="form-label text-white-50">Confirm Password</label>
                        <input asp-for="ConfirmNewPassword" type="password"
                               class="form-control bg-dark text-white border-secondary"
                               placeholder="Confirm new password" required />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                    </div>

                    <!-- Error messages -->
                    <div>
                        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                    </div>

                    <!-- Submit -->
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-success fw-semibold py-2">
                            Update Password
                        </button>
                    </div>

                </form>

                <!-- Footer -->
                <div class="text-center mt-4">
                    <span class="text-white-50">Remember your password?</span>
                    <a asp-controller="Account" asp-action="Login" class="text-success fw-semibold text-decoration-none">
                        Login
                    </a>
                </div>

            </div>
        </div>

        <!-- RIGHT: Image -->
        <div class="col-md-6 d-none d-md-block">
            <img src="~/images/hat.jpg"
                 alt="Change Password Image"
                 class="w-100 h-100"
                 style="object-fit: cover; object-position: center; filter: brightness(85%);">
        </div>

    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
