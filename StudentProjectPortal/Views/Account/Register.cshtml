@using StudentProjectPortal.ViewModels;
@model RegisterViewModel;

@{
    ViewBag.Title = "Register";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container-fluid min-vh-100 d-flex p-0 bg-dark">
    <div class="row flex-fill g-0">

        <!-- LEFT: FORM -->
        <div class="col-12 col-md-6 d-flex align-items-center justify-content-center p-4">
            <div class="card shadow-lg rounded-4 p-4 w-100" style="max-width: 480px; background: #1e1f24; border: none;">

                <!-- HEADER -->
                <div class="text-center mb-4 text-white">
                    <h2 class="fw-bold">Create Your Account</h2>
                    <p class="text-secondary">Join Project Hub and start managing your projects easily.</p>
                </div>

                <!-- ERROR MESSAGES -->
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- FORM -->
                <form asp-action="Register" asp-controller="Account" method="post" novalidate>

                    <!-- Full Name -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label text-white-50"></label>
                        <input asp-for="Name" class="form-control bg-dark text-white border-secondary rounded-3" placeholder="Enter your name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-white-50"></label>
                        <input asp-for="Email" class="form-control bg-dark text-white border-secondary rounded-3" placeholder="me@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label text-white-50"></label>
                        <input asp-for="Password" class="form-control bg-dark text-white border-secondary rounded-3" placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label text-white-50"></label>
                        <input asp-for="ConfirmPassword" class="form-control bg-dark text-white border-secondary rounded-3" placeholder="Confirm password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <!-- Class -->
                    <div class="mb-3">
                        <label asp-for="ClassId" class="form-label text-white-50"></label>
                        <input asp-for="ClassId" list="ClassList" class="form-control bg-dark text-white border-secondary rounded-3" placeholder="Type or choose class" />
                        <datalist id="ClassList">
                            <option value="Level 100" />
                            <option value="Level 200" />
                            <option value="Level 300" />
                            <option value="Level 400" />
                            <option value="Level 500" />
                            <option value="Level 600" />
                            <option value="Masters" />
                            <option value="PhD" />
                        </datalist>
                        <span asp-validation-for="ClassId" class="text-danger"></span>
                    </div>

                    <!-- SUBMIT -->
                    <div class="d-grid mt-3">
                        <button type="submit" class="btn btn-success py-2 fw-semibold rounded-3">
                            Register
                        </button>
                    </div>
                </form>

                <!-- FOOTER LINKS -->
                <div class="text-center mt-4">
                    <span class="text-white-50">Already registered?</span>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-link text-success fw-semibold text-decoration-none">
                        Login
                    </a>
                </div>

                <div class="text-center mt-2">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm rounded-3">
                        &larr; Back to Home
                    </a>
                </div>
            </div>
        </div>

        <!-- RIGHT: IMAGE -->
        <div class="col-md-6 d-none d-md-block">
            <img src="~/images/hat.jpg"
                 class="img-fluid h-100"
                 style="object-fit: cover; object-position: center; filter: brightness(88%);" />
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
