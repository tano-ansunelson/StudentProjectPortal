@{
    ViewBag.Title = "Verify Email";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container-fluid min-vh-100 d-flex p-0">
    <div class="row flex-fill g-0">

        <!-- LEFT: VERIFY EMAIL FORM -->
        <div class="col-12 col-md-6 d-flex align-items-center justify-content-center bg-dark p-4">

            <div class="card shadow-lg rounded-4 p-4 w-100"
                 style="max-width: 420px; background: #1e1f24; border: 1px solid rgba(255,255,255,0.05);">

                <!-- Header -->
                <div class="text-center mb-4 text-white">
                    <h2 class="fw-bold mb-1">Verify Your Email</h2>
                    <p class="text-secondary">Enter your registered email to continue</p>
                </div>

                <!-- Form -->
                <form method="post" class="animate__animated animate__fadeIn">

                    <!-- Email Input -->
                    <div class="mb-3">
                        <label for="Email" class="form-label text-white-50">Email</label>
                        <input type="email"
                               id="Email"
                               name="Email"
                               required
                               placeholder="your-email@example.com"
                               class="form-control bg-dark text-white border-secondary rounded-3" />
                    </div>

                    <!-- Submit Button -->
                    <div class="d-grid mt-3">
                        <button type="submit" class="btn btn-success fw-semibold py-2 rounded-3">
                            Verify Email
                        </button>
                    </div>
                </form>

                <!-- Return to login -->
                <div class="text-center mt-4">
                    <span class="text-white-50">Back to</span>
                    <a asp-controller="Account" asp-action="Login"
                       class="text-success fw-semibold text-decoration-none">
                        Login
                    </a>
                </div>
            </div>
        </div>

        <!-- RIGHT: Image Panel -->
        <div class="col-md-6 d-none d-md-block">
            <img src="~/images/hat.jpg"
                 alt="Verify Email Image"
                 class="w-100 h-100"
                 style="object-fit: cover; object-position: center; filter: brightness(85%);">
        </div>

    </div>
</div>
