@{
    ViewData["Title"] = "Home Page";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academic Portal - Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light">

    <div class="container-fluid min-vh-100 d-flex flex-column flex-md-row align-items-center justify-content-between py-5 px-4">

        <!-- Left Side Text -->
        <div class="col-md-6 mb-4 mb-md-0">
            <h1 class="display-4 fw-bold">
                Manage Your <span class="text-success">Academic Projects</span>
            </h1>
            <p class="lead text-secondary mt-3">
                Academic Portal is a centralized platform for students to submit assignments,
                track projects, and for supervisors to manage research efficiently.
            </p>

            <div class="mt-4">
                <a asp-controller="Account" asp-action="Login" class="btn btn-success btn-lg me-2">
                    Get Started
                </a>
                <a asp-controller="Home" asp-action="About" class="btn btn-outline-light btn-lg">
                    Learn More
                </a>
            </div>
        </div>

        <!-- Right Side Image -->
        <div class="col-md-6 d-flex justify-content-center">
            <img src="~/images/hat.jpg" alt="Academic Projects Image" class="img-fluid rounded shadow-lg" style="max-height: 450px; object-fit: cover;">
        </div>

    </div>

    <div class="bg-body-tertiary">
        @Html.Partial("_AdditionalPage")
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
