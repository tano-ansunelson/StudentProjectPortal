@using StudentProjectPortal.ViewModels;
@model SuperVisorResetPasswordViewModel;

@{
    ViewBag.Title = "Reset Password";
}

<div class="container min-vh-100 d-flex align-items-center justify-content-center py-4"
     style="padding-left: 40px; padding-right: 40px;">

    <div class="row w-100 shadow-lg rounded-4 overflow-hidden"
         style="max-width: 1100px; margin-left:auto; margin-right:auto; background: #1e1f24;">

        <!-- LEFT SIDE: FORM -->
        <div class="col-12 col-md-6 p-4 d-flex align-items-center justify-content-center"
             style="background: #1e1f24;">

            <div class="w-100" style="max-width: 420px;">

                <div class="text-center mb-4 text-white">
                    <h2 class="fw-bold">Reset Password</h2>
                    <p class="text-secondary">Enter a new password to update your account.</p>
                </div>

                <form asp-action="ResetPassword" asp-controller="Supervisor" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- EMAIL (READONLY) -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-white-50">Email</label>
                        <input asp-for="Email" readonly
                               class="form-control bg-dark text-white border-secondary rounded-3" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- New Password -->
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label text-white-50">New Password</label>
                        <input asp-for="NewPassword" type="password"
                               class="form-control bg-dark text-white border-secondary rounded-3"
                               placeholder="Enter new password" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label text-white-50">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password"
                               class="form-control bg-dark text-white border-secondary rounded-3"
                               placeholder="Confirm your new password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <!-- SUBMIT BUTTON -->
                    <div class="d-grid mt-3">
                        <button type="submit" class="btn btn-success py-2 fw-semibold rounded-3">
                            Update Password
                        </button>
                    </div>

                </form>

                <!-- BACK TO LOGIN -->
                <div class="text-center mt-4">
                    <a asp-controller="Supervisor" asp-action="SuperVisorLogin"
                       class="text-success fw-semibold text-decoration-none">
                        ← Back to Login
                    </a>
                </div>

            </div>
        </div>

        <!-- RIGHT: IMAGE -->
        <div class="col-md-6 d-none d-md-block p-0">
            <img src="~/images/hat.jpg"
                 class="img-fluid h-100 w-100"
                 style="object-fit: cover; filter: brightness(88%);" />
        </div>

    </div>
</div>