@model StudentProjectPortal.ViewModels.SuperVisorRegisterModel
@{
    ViewBag.Title = "SuperVisorRegister";
  
}

<div class="container min-vh-100 d-flex align-items-center justify-content-center py-4"
     style="padding-left: 40px; padding-right: 40px;">

    <div class="row w-100 shadow-lg rounded-4 overflow-hidden"
         style="max-width: 1100px; margin-left:auto; margin-right:auto; background: #1e1f24;">

        <!-- LEFT: FORM -->
        <div class="col-12 col-md-6 p-4 d-flex align-items-center justify-content-center"
             style="background: #1e1f24;">
            <div class="w-100" style="max-width: 420px;">

                <div class="text-center mb-4 text-white">
                    <h2 class="fw-bold">Create Your Account</h2>
                    <p class="text-secondary">Join Project Hub and manage your projects easily.</p>
                </div>

                <form asp-action="SuperVisorRegister" asp-controller="Supervisor" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Full Name -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label text-white-50"></label>
                        <input asp-for="Name" class="form-control bg-dark text-white border-secondary rounded-3"
                               placeholder="Enter your full name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-white-50"></label>
                        <input asp-for="Email" class="form-control bg-dark text-white border-secondary rounded-3"
                               placeholder="me@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label text-white-50"></label>
                        <input asp-for="Password" type="password"
                               class="form-control bg-dark text-white border-secondary rounded-3"
                               placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label text-white-50"></label>
                        <input asp-for="ConfirmPassword" type="password"
                               class="form-control bg-dark text-white border-secondary rounded-3"
                               placeholder="Confirm password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <!-- Staff ID -->
                    <div class="mb-3">
                        <label asp-for="StaffId" class="form-label text-white-50">Staff ID</label>
                        <input asp-for="StaffId"
                               class="form-control bg-dark text-white border-secondary rounded-3"
                               placeholder="Your Staff ID" />
                        <span asp-validation-for="StaffId" class="text-danger"></span>
                    </div>

                    <!-- Department -->
                    <div class="mb-3">
                        <label asp-for="Department" class="form-label text-white-50"></label>
                        <input asp-for="Department"
                               class="form-control bg-dark text-white border-secondary rounded-3"
                               placeholder="Department" />
                        <span asp-validation-for="Department" class="text-danger"></span>
                    </div>

                    <!-- SUBMIT BUTTON -->
                    <div class="d-grid mt-3">
                        <button type="submit" class="btn btn-success py-2 fw-semibold rounded-3">
                            Register
                        </button>
                    </div>
                </form>

                <!-- FOOTER -->
                <div class="text-center mt-4">
                    <span class="text-white-50">Already registered?</span>
                    <a asp-controller="Supervisor" asp-action="SuperVisorLogin"
                       class="btn btn-link text-success fw-semibold text-decoration-none">
                        Login
                    </a>
                </div>

                <div class="text-center mt-2">
                    <a asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-light btn-sm rounded-3">
                        ← Back to Home
                    </a>
                </div>

            </div>
        </div>

        <!-- RIGHT: IMAGE -->
        <div class="col-md-6 d-none d-md-block p-0">
            <img src="~/images/hat.jpg"
                 class="img-fluid h-100 w-100"
                 style="object-fit: cover; filter: brightness(88%);" />
        </div>

    </div>
</div>
